# Cesium Ion access token (get free at https://ion.cesium.com/tokens)
VITE_CESIUM_ION_TOKEN= your-cesium-ion-token-here

# Backend URL
VITE_API_BASE_URL=http://localhost:8000

# Backend settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
GIBS_CAPABILITIES_CACHE_TTL=21600

# NASA FIRMS MAP_KEY for live wildfire data (optional – mock data used when empty)
# Get a free key at https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY= your-map-key-here
